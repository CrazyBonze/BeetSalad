# ============================================================
# Secret API keys — copy this file to config.secret.yaml
# and fill in your credentials. Never commit config.secret.yaml.
# ============================================================
#
# How to get these keys:
#   fanarttv_key    — https://fanart.tv/get-an-api-key/
#   lastfm_key      — https://www.last.fm/api/account/create
#   discogs_token   — https://www.discogs.com/settings/developers
#   spotify_*       — https://developer.spotify.com/dashboard
#   navidrome       — your self-hosted Navidrome server credentials

fetchart:
  fanarttv_key: YOUR_FANARTTV_KEY
  lastfm_key: YOUR_LASTFM_KEY

fetchartextras:
  discogs_token: YOUR_DISCOGS_TOKEN

fetchartist:
  fanarttv_key: YOUR_FANARTTV_KEY
  discogs_token: YOUR_DISCOGS_TOKEN
  spotify_client_id: YOUR_SPOTIFY_CLIENT_ID
  spotify_client_secret: YOUR_SPOTIFY_CLIENT_SECRET

# Uncomment and fill in to enable the navidrome_sync plugin
# navidrome_sync:
#   url: http://YOUR_NAVIDROME_HOST:PORT
#   user: YOUR_USERNAME
#   pass: YOUR_PASSWORD
#   auth: token         # or "password"
#   api_version: "1.16.1"
